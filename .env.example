# ==============================================================================
# CONFIGURACIÓN DEL PROYECTO SUBVENIA
# ==============================================================================
# IMPORTANTE: El proyecto NO funcionará correctamente si estas variables no 
# están configuradas. Asegúrate de rellenarlas antes de iniciar los servicios.
# ==============================================================================

# 1. API Key de Google Gemini
# Requerida por el Módulo 1 (Scraper) para enriquecer las convocatorias mediante
# procesamiento de lenguaje natural y extracción estructurada.
# Consíguela en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="PON_TU_API_KEY_AQUI"

# 2. URI de Conexión a MongoDB Atlas
# Requerida por todos los módulos. Almacena las convocatorias, los vectores (embeddings)
# y es consultada por el sistema RAG para proporcionar contexto al asistente.
# Formato típico: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/
MONGO_URI="PON_TU_MONGO_URI_AQUI"
